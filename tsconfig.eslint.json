{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true
  },
  "include": [
    "src/**/*",
    "prisma/**/*",
    "test/**/*.ts",
    "scripts/**/*.ts",
    "tools/**/*.ts",
    "prisma.config.ts",
    "jest.config.ts"
  ],
  "exclude": ["node_modules", "build", "dist", "src/generated"]
}
