# Database (MySQL)
DATABASE_URL="mysql://USER:PASSWORD@localhost:3306/boilerplate_nest"

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Swagger basic auth (optional)
SWAGGER_USERNAME=admin
SWAGGER_PASSWORD=admin

# Server port (optional, default 3000)
PORT=3000

# Seed: password for default superadmin (optional, default: Superadmin123!)
# SUPER_ADMIN_PASSWORD_SEED=Superadmin123!

# Docker Compose (optional)
# MYSQL_ROOT_PASSWORD=rootpassword
# MYSQL_DATABASE=boilerplate_nest
# MYSQL_USER=app
# MYSQL_PASSWORD=apppassword
# RUN_SEED=true
