# =========================
# Backend
# =========================
PORT_BE=3000

# =========================
# PostgreSQL
# =========================
DB_HOST=boilerplate-nest-database-postgres-dev
DB_PORT=5432
DB_NAME=boilerplate_nest
DB_USER=app
DB_PASSWORD=apppassword
POSTGRES_USER=app
POSTGRES_PASSWORD=apppassword
POSTGRES_DB=boilerplate_nest

# =========================
# Prisma
# =========================
DATABASE_URL_DEV=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${DB_HOST}:${DB_PORT}/${POSTGRES_DB}

# =========================
# Auth
# =========================
JWT_SECRET=your-super-secret-jwt-key
SUPER_ADMIN_PASSWORD_SEED=Superadmin123!

# =========================
# Swagger
# =========================
SWAGGER_USERNAME=admin
SWAGGER_PASSWORD=admin
