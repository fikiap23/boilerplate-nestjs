# Production env file. Copy to build/.env.production and use: make up-prod

DATABASE_URL=postgresql://USER:PASSWORD@boilerplate-nest-database-postgres-production:5432/boilerplate_nest
POSTGRES_USER=app
POSTGRES_PASSWORD=apppassword
POSTGRES_DB=boilerplate_nest

REDIS_HOST=boilerplate-nest-redis-production
REDIS_PORT=6379
REDIS_PREFIX=bn
REDIS_DEFAULT_TTL=300

JWT_SECRET=your-production-jwt-secret-must-be-at-least-32-characters-long
SUPER_ADMIN_PASSWORD_SEED=Superadmin123!
SWAGGER_USERNAME=admin
SWAGGER_PASSWORD=admin

# ENABLE_SWAGGER=false
# CORS_ORIGINS=https://your-frontend.example.com

RUN_SEED=0
