# Production env file. Copy to build/.env.production and use: make up-prod

DATABASE_URL=mysql://USER:PASSWORD@boilerplate-nest-database-mysql-production:3306/boilerplate_nest
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=boilerplate_nest
MYSQL_USER=app
MYSQL_PASSWORD=apppassword

JWT_SECRET=your-production-jwt-secret
SUPER_ADMIN_PASSWORD_SEED=Superadmin123!
SWAGGER_USERNAME=admin
SWAGGER_PASSWORD=admin

RUN_SEED=0
